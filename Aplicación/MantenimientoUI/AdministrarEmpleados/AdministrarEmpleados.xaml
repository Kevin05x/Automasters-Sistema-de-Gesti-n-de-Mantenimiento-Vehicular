<UserControl x:Class="MantenimientoUI.VentanasDer.AdmEmployees"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MantenimientoUI.VentanasDer"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">
    <Grid>
        <Grid>
            <Label HorizontalAlignment="Left" Margin="120,94,0,0"  Content="EMPLEADOS" VerticalAlignment="Top" Width="625" FontSize="75" FontWeight="Bold" Style="{StaticResource Títulos}"/>
            <ComboBox x:Name="cbxFiltrarEmp" HorizontalAlignment="Left" Margin="1176,139,0,0" VerticalAlignment="Top" FontSize="23" Width="304" Height="50" SelectionChanged="cbxFiltrarEmp_SelectionChanged" />
            <Button x:Name="btnRegistrar" Content="Registrar empleado" HorizontalAlignment="Left" Margin="352,754,0,0" VerticalAlignment="Top" Height="60" Width="272" FontSize="30"  Click="btnRegistrar_Click"/>
            <Button x:Name="btnActualizar" Content="Actualizar datos del empleado" HorizontalAlignment="Left" Margin="874,754,0,0" VerticalAlignment="Top" Height="60" Width="359" FontSize="30" Click="btnActualizar_Click" />
            <DataGrid x:Name="dgListadoEmpleado" Margin="120,233,120,171"  FontSize="24.5"  MaxHeight="400" IsReadOnly="True"/>
            <Label Content="Filtrar: " HorizontalAlignment="Left" Margin="1041,139,0,0" VerticalAlignment="Top" Height="50" Width="111"  FontSize="35"/>
        </Grid>
    </Grid>
</UserControl>
