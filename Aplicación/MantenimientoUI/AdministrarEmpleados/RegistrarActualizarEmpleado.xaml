<Window x:Class="MantenimientoUI.VentanasEmer.Registrar_ActualizarEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MantenimientoUI.VentanasEmer"
        mc:Ignorable="d"
        Title="Registrar_ActualizarEmpleado" Height="600" Width="1200"
        WindowStartupLocation="CenterScreen">



    <Grid x:Name="RegistraryActualizarEmpleado" Background="#1e1e1e">
        <Label Content="Nombre:" HorizontalAlignment="Left" Margin="116,128,0,0" VerticalAlignment="Top" Height="50" Width="96" FontSize="25"/>
        <Label Content="Apellidos:" HorizontalAlignment="Left" Margin="600,128,0,0" VerticalAlignment="Top" Height="50" Width="116"  FontSize="25"/>
        <Label Content="Telefono:" HorizontalAlignment="Left" Margin="116,214,0,0" VerticalAlignment="Top" Height="50" Width="116"  FontSize="25"/>
        <Label Content="Salario:" HorizontalAlignment="Left" Margin="600,214,0,0" VerticalAlignment="Top" Height="50" Width="96" FontSize="25"/>
        <Label Content="Usuario:" HorizontalAlignment="Left" Margin="116,296,0,0" VerticalAlignment="Top" Height="50" Width="96"  FontSize="25"/>
        <Label Content="Password:" HorizontalAlignment="Left" Margin="600,296,0,0" VerticalAlignment="Top" Height="50" Width="138" FontSize="25"/>
        <Label Content="Tipo:" HorizontalAlignment="Left" Margin="116,386,0,0" VerticalAlignment="Top" Height="50" Width="96"  FontSize="25"/>
        <TextBox x:Name="txtUsuario" HorizontalAlignment="Left" Margin="244,296,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtTelefono" HorizontalAlignment="Left" Margin="244,214,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="244,128,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtApellidos" HorizontalAlignment="Left" Margin="800,128,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtSalario" HorizontalAlignment="Left" Margin="800,214,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtPassword" HorizontalAlignment="Left" Margin="800,296,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="300" Height="50"  FontSize="25"/>
        <ComboBox x:Name="cbxFiltrarEmp" HorizontalAlignment="Left" Margin="244,386,0,0" VerticalAlignment="Top" Width="300" Height="50" FontSize="25" SelectionChanged="cbxFiltrarEmp_SelectionChanged" />
        <Button x:Name="btnRegistrar" Content="Registrar empleado" HorizontalAlignment="Left" Margin="444,487,0,0" VerticalAlignment="Top" Height="60" Width="272" FontSize="25"  Click="btnRegistrar_Click"/>
        <Button x:Name="btnActualizar" Content="Actualizar datos del empleado" HorizontalAlignment="Center" Margin="0,482,0,0" VerticalAlignment="Top" Height="60" Width="360" FontSize="25" Click="btnActualizar_Click" Visibility="Collapsed"/>
        <TextBox x:Name="txtEmpleadoActual" HorizontalAlignment="Left" Margin="800,386,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="113" Height="50"  FontSize="25" IsEnabled="False"/>
        <Label Content="Id Empleado actual:" HorizontalAlignment="Left" Margin="600,386,0,0" VerticalAlignment="Top" Height="50" Width="230"  FontSize="25"/>
        <Label Content="Registrar o Actualizar empleado" HorizontalAlignment="Center" Margin="0,34,0,0" VerticalAlignment="Top" Height="89" Width="992" FontSize="43" Style="{StaticResource Títulos}"/>

    </Grid>

</Window>
