<UserControl x:Class="MantenimientoUI.VentanasDer.AdmSuppliers"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MantenimientoUI.VentanasDer"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">
    <Grid >
        <Grid Margin="0,10,-10,-10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="599*" />
            </Grid.ColumnDefinitions>

            <Label Content="Buscar (nombre):" HorizontalAlignment="Left" Margin="948,96,0,0" VerticalAlignment="Top" Height="50" Width="188" FontSize="25" FontWeight="Normal" Grid.Column="1" />
            <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="1116,89,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="280" Height="50" FontSize="25"  TextChanged="txtNombre_TextChanged" Grid.Column="1"/>

            <DataGrid Name="ProveedoresDataGrid" Margin="139,187,113,262" Grid.Column="1" IsReadOnly="True"/>


            <Label Grid.Column="1" Content="Proveedores" FontSize="70" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="139,47,0,0" Height="135" Width="729" FontWeight="Bold" Style="{StaticResource Títulos}"/>

            <!-- Botones -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,769,0,0" Width="551" Height="68">
                <Button x:Name="btnAñadirProveedor" Content="Añadir Proveedor" Width="204" Margin="10" Click="btnAñadirProveedor_Click"/>
                <Button x:Name="btnActualizarProveedor" Content="Actualizar datos del proveedor" Width="306" Margin="10" Click="btnActualizarProveedor_Click" />
            </StackPanel>
            <Button x:Name="btnBuscar" Content="🔎" HorizontalAlignment="Left" Margin="1401,89,0,0" VerticalAlignment="Top" Height="50" Width="77" FontSize="25" Grid.Column="1"/>



        </Grid>
    </Grid>
</UserControl>
