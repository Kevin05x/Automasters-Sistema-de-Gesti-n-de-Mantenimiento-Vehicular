<Window x:Class="MantenimientoUI.VentanasEmer.Registrar_ActualizarProveedor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MantenimientoUI.VentanasEmer"
        mc:Ignorable="d"
        Title="Registrar_ActualizarProveedor" Height="800" Width="800">
    <Grid Background="#1e1e1e">
        <Label Content="Registrar o Actualizar proveedor" Height="60" VerticalAlignment="Top" Margin="10,10,-18,0" FontSize="35" Style="{StaticResource Títulos}"/>
        <StackPanel Margin="20" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Label Content="ID:" FontWeight="Bold"/>
                <TextBox x:Name="txtId" Padding="5" Margin="0,5,0,0" Background="WhiteSmoke" IsEnabled="False"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Label Content="RUC:" FontWeight="Bold"/>
                <TextBox x:Name="txtRUC" Padding="5" Margin="0,5,0,0" Background="WhiteSmoke"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Label Content="Nombre:" FontWeight="Bold"/>
                <TextBox x:Name="txtNombre" Padding="5" Margin="0,5,0,0" Background="WhiteSmoke"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Label Content="Dirección:" FontWeight="Bold"/>
                <TextBox x:Name="txtDireccion" Padding="5" Margin="0,5,0,0" Background="WhiteSmoke"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Label Content="Teléfono:" FontWeight="Bold"/>
                <TextBox x:Name="txtTelefono" Padding="5" Margin="0,5,0,0" Background="WhiteSmoke"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Label Content="Correo:" FontWeight="Bold"/>
                <TextBox x:Name="txtCorreo" Padding="5" Margin="0,5,0,0" Background="WhiteSmoke"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                <Button x:Name="btnRegistrar" Content="Registrar" Width="120" Margin="10" Padding="5" Foreground="LightBlue" FontWeight="Bold" Click="btnRegistrar_Click"/>
                <Button x:Name="btnActualizar" Content="Actualizar" Width="120" Margin="10" Padding="5"  Foreground="GreenYellow" FontWeight="Bold" Click="btnActualizar_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
