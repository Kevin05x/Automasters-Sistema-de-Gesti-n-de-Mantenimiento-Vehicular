<Window x:Class="MantenimientoUI.VentanasEmer.Registrar_ActualizarRpuesto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MantenimientoUI.VentanasEmer"
        mc:Ignorable="d"
        Title="Registrar_ActualizarRpuesto" Height="900" Width="1600">
    <Grid Background="#1E1E1E">
        <Label Content="Id Proveedor:" HorizontalAlignment="Left" Margin="189,207,0,0" VerticalAlignment="Top" Height="50" Width="157"  FontSize="30"/>
        <Label Content="Nombre:" HorizontalAlignment="Left" Margin="917,207,0,0" VerticalAlignment="Top" Height="50" Width="116"  FontSize="30"/>
        <Label Content="Descripción:" HorizontalAlignment="Left" Margin="189,293,0,0" VerticalAlignment="Top" Height="50" Width="134"  FontSize="30"/>
        <Label Content="Precio Unitario:" HorizontalAlignment="Left" Margin="917,293,0,0" VerticalAlignment="Top" Height="50" Width="180"  FontSize="30"/>
        <Label Content="Stock:" HorizontalAlignment="Left" Margin="917,375,0,0" VerticalAlignment="Top" Height="50" Width="85" FontSize="30"/>
        <TextBox x:Name="txtDescripcion" HorizontalAlignment="Left" Margin="351,293,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="432" Height="314" FontSize="30"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="1055,207,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="466" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtPrecio" HorizontalAlignment="Left" Margin="1102,293,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="419" Height="50"  FontSize="25"/>
        <TextBox x:Name="txtStock" HorizontalAlignment="Left" Margin="1055,375,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="152" Height="50"  FontSize="25"/>
        <ComboBox x:Name="cbxProveedor" HorizontalAlignment="Left" Margin="351,207,0,0" VerticalAlignment="Top" Width="352" Height="50" FontSize="25"/>
        <Button x:Name="btnRegistrar" Content="Registrar Repuesto" HorizontalAlignment="Center" Margin="0,720,0,0" VerticalAlignment="Top" Height="60" Width="272" FontSize="25" Click="btnRegistrar_Click"/>
        <Button x:Name="btnActualizar" Content="Actualizar datos del Repuesto" HorizontalAlignment="Center" Margin="0,738,0,0" VerticalAlignment="Top" Height="60" Width="360" FontSize="25"  Click="btnActualizar_Click" Visibility="Collapsed"/>
        <TextBox x:Name="txtIdPro" HorizontalAlignment="Left" Margin="1164,463,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="113" Height="50"  FontSize="25" IsEnabled="False"/>
        <Label Content="Id Proveedor actual:" HorizontalAlignment="Left" Margin="929,463,0,0" VerticalAlignment="Top" Height="50" Width="230"  FontSize="25"/>
        <TextBox x:Name="txtRepuestoActual" HorizontalAlignment="Left" Margin="1164,530,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="113" Height="50" FontSize="25" IsEnabled="False"/>
        <Label Content="Id Repuesto actual:" HorizontalAlignment="Left" Margin="929,530,0,0" VerticalAlignment="Top" Height="50" Width="230"  FontSize="25"/>
        <Label Content="REGISTRAR O ACTUALIZAR REPUESTO" HorizontalAlignment="Left" Margin="99,57,0,0" VerticalAlignment="Top" Height="77" Width="1178"  FontSize="50" Style="{StaticResource Títulos}"/>
    </Grid>
</Window>
