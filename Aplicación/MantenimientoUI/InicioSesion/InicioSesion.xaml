<Window x:Class="MantenimientoUI.IniciarSesion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MantenimientoUI"
        mc:Ignorable="d"
        Title="IniciarSesion" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        >
    <Grid Background="#1E1E1E">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="AUTOMASTERS" Grid.Row="0" FontSize="70" FontWeight="Bold" HorizontalContentAlignment="Center" Style="{StaticResource Títulos}" Margin="0,20,0,0"/>

            <Label Content="Usuario:" Grid.Row="1" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-200,-80,0,0" />
            <TextBox x:Name="TBUser" Grid.Row="1" FontSize="25" FontWeight="Light" HorizontalAlignment="Center" VerticalAlignment="Center" Margin=" 130,-80,0,0" Width="200" Height="40" ToolTip="Hola" />

            <Label Content="Contraseña:" Grid.Row="1" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-240,80,0,0"  RenderTransformOrigin="-140937588778.226,2049121930.076" />
            <PasswordBox  x:Name="PBUser" Grid.Row="1" FontSize="25" FontWeight="Light" HorizontalAlignment="Center" VerticalAlignment="Center" Margin=" 130,80,0,0" Width="200" Height="40" Style="{StaticResource PswCasilla}"/>

            <Button x:Name="BtnIniciarSesion"  Grid.Row="2" Content="INICIAR SESIÓN" Height="60" Width="200" Click="BtnIniciarSesion_Click" Style="{StaticResource Botones}" />

        </Grid>

          
    </Grid> 
</Window>
