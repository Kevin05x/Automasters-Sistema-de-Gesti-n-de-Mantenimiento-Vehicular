<Window x:Class="MantenimientoUI.VentanasEmer.RegistrarPago"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MantenimientoUI.VentanasEmer"
        mc:Ignorable="d"
        Title="RegistrarPago" Height="450" Width="800">
    <Grid Background="#1E1E1E">
        <Rectangle HorizontalAlignment="Center" Height="266" Margin="0,111,0,0" Stroke="White" VerticalAlignment="Top" Width="610" OpacityMask="Black" Fill="#3e3e3e"/>
        <Label Content="PAGO" HorizontalAlignment="Left" Margin="95,10,0,0" VerticalAlignment="Top" Style="{StaticResource Títulos}" FontSize="50"/>
        <Label Content="Método de pago:" HorizontalAlignment="Left" Margin="170,144,0,0" VerticalAlignment="Top"  FontSize="20"/>
        <Label Content="Tipo de pago:" HorizontalAlignment="Left" Margin="452,148,0,0" VerticalAlignment="Top"  FontSize="20"/>
        <ComboBox x:Name="cmbxMetodoPago" HorizontalAlignment="Left" Margin="170,185,0,0" VerticalAlignment="Top" Width="142" FontSize="16" Height="28">
            <ComboBoxItem Content="Efectivo"/>
            <ComboBoxItem Content="Tarjeta de crédito"/>
            <ComboBoxItem Content="Transferencia Bancaria"/>
        </ComboBox>
        <ComboBox x:Name="cmbxTipoPago" HorizontalAlignment="Left" Margin="452,185,0,0" VerticalAlignment="Top" Width="142" FontSize="16" Height="28" SelectionChanged="cmbxTipoPago_SelectionChanged"/>
        <Label Content="Monto: S/." HorizontalAlignment="Left" Margin="286,230,0,0" VerticalAlignment="Top" FontSize="20"/>
        <TextBox x:Name="tbxMonto" HorizontalAlignment="Left" Margin="382,230,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="119" FontSize="16"  Height="28" IsEnabled="False"/>
        <Button x:Name="bttnRegistrarPago" Content="Registrar Pago" HorizontalAlignment="Center" Margin="0,314,0,0" VerticalAlignment="Top" FontSize="16"  Height="43" Width="130" Click="bttnRegistrarPago_Click"/>
        <Label x:Name="lbTipoPago" Content="Adelanto: S/." HorizontalAlignment="Left" Margin="278,275,0,0" VerticalAlignment="Top" FontSize="16" Visibility="Collapsed"/>
        <TextBox x:Name="tbxMontoAsignado" HorizontalAlignment="Left" Margin="382,275,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="119" FontSize="16"  Height="28" Visibility="Collapsed"/>
    </Grid>
</Window>
