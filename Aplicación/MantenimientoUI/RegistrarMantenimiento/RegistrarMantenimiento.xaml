<UserControl x:Class="MantenimientoUI.RegMantenimiento"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MantenimientoUI"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1600">
    <Grid >

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition  MinHeight="80" MaxHeight="170"/>
            <RowDefinition  MinHeight="80" MaxHeight="80"/>
            <RowDefinition  MinHeight="220" MaxHeight="750"/>
        </Grid.RowDefinitions>

        <Label  FontSize="60" FontWeight="Bold" Grid.ColumnSpan="3" Style="{StaticResource Títulos}" Margin="2">
            <TextBlock>
                <Run Text="REGISTRO DE"/>
                <LineBreak/>
                <Run Text="      MANTENIMIENTO"/>
            </TextBlock>
        </Label>

        <Grid Grid.Column="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <Label Content="COSTO TOTAL(s/):" FontSize="30" FontWeight="Bold" Grid.Column="0"  VerticalContentAlignment="Center" />
            <Label x:Name="lblTotal" Content="x"  FontSize="40" FontWeight="Light" Grid.Column="1"  VerticalContentAlignment="Center" HorizontalContentAlignment="Right"  MinWidth="50"/>
            <Button x:Name="btnRegistrarMant" Content="Registrar" Grid.Column="2" MinHeight="50" MinWidth="120" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="21" Margin="10" Click="btnRegistrarMant_Click" />

        </Grid>


        <Label Content="Cliente" Grid.Row="1" FontSize="60" HorizontalContentAlignment="Center" Foreground="DarkGray"/>


        <Grid Grid.Column="0" Grid.Row="2" >
            <Grid.RowDefinitions>
                <RowDefinition MinHeight="200" Height="Auto"/>
                <RowDefinition MinHeight="200"/>
            </Grid.RowDefinitions>

            <Label Content="Nombre Cliente:"  Grid.Row="0" Grid.Column="0" FontWeight="Bold" FontSize="25" Margin="20,50,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBox  x:Name="TbClientName" Margin="270,50,0,0" Grid.Row="0" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Label Content="Telefono del cliente:"  Grid.Row="0" Grid.Column="0" FontWeight="Bold" FontSize="25" Margin="20,120,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBox  x:Name="TbTelProp" Margin="270,120,0,0" Grid.Row="0" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top" PreviewTextInput="TextBox_PreviewTextInput" PreviewKeyDown= "TextBox_PreviewKeyDown"/>

            <Label Content="Empleado" Grid.Row="1" FontSize="60" HorizontalContentAlignment="Center"/>
            <Label Content="Empleado encargado:"  Grid.Row="1" Grid.Column="0" FontWeight="Bold" FontSize="22" Margin="20,120,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <ComboBox x:Name="cmbMecanicos" Width="200" Height="45"  Margin="270,120,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.Row="1"/>

        </Grid>


        <Rectangle  Fill="gray" Grid.Column="1" Grid.Row="2" Margin="0,4,0,4"/>

        <Label Content="Vehículo" Grid.Row="1" FontSize="60" HorizontalContentAlignment="Center" Grid.Column="2" Foreground="DarkGray"/>

        <Grid Grid.Row="2" Grid.Column="2">

            <Grid.RowDefinitions>
                <RowDefinition  Height="Auto"/>
                <RowDefinition  Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="Marca:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,50,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBox x:Name="TbMarca" Grid.Row="0" Grid.Column="2" Margin="220,50,0,20" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Label Content="Modelo:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,120,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBox  x:Name="TbModelo" Margin="220,123,0,20" Grid.Row="0" Grid.Column="2" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Label Content="Placa:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,190,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBox  x:Name="TbPlaca" Margin="220,190,0,20" Grid.Row="0" Grid.Column="2" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Label Content="Kilometraje:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,260,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left" />
            <TextBox  x:Name="TbKilometraje" Margin="220,260,0,20" Grid.Row="0" Grid.Column="2" Height="40" VerticalAlignment="Top" HorizontalAlignment="Left" Width="200" PreviewTextInput="TextBox_PreviewTextInput" PreviewKeyDown= "TextBox_PreviewKeyDown"/>

            <Label Content="Color:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,330,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <ComboBox  x:Name="cmbCOlor" Margin="220,330,0,20" Grid.Row="0" Grid.Column="2" Height="40" VerticalAlignment="Top" HorizontalAlignment="Left" Width="200"/>

            <Label Content="Año:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,400,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <ComboBox  x:Name="cmbAño" Margin="220,400,0,20" Grid.Row="0" Grid.Column="2" Height="40" VerticalAlignment="Top" HorizontalAlignment="Left" Width="200"/>

            <Label Content="Tipo:"  Grid.Row="0" Grid.Column="2" FontWeight="Bold" FontSize="25" Margin="20,470,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <ComboBox  x:Name="cmbTipo" Margin="220,470,0,20" Grid.Row="0" Grid.Column="2" Height="40" VerticalAlignment="Top" HorizontalAlignment="Left" Width="200"/>


            <Label Content="Repuestos" Grid.Row="1" FontSize="40" HorizontalContentAlignment="Center" VerticalAlignment="Top" />

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="20,55,0,0" Width="Auto" Height="Auto" MaxHeight="300" Grid.Row="1">


                <Grid Width="Auto" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="Auto"/>
                        <ColumnDefinition  Width="Auto"/>
                        <ColumnDefinition  Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="StackRep" Grid.Row="0" Width="Auto">
                        <ComboBox x:Name="Cb1Repuestos" Width="250" Height="40" Margin="5" SelectionChanged="Cb1Repuestos_SelectionChanged"/>
                    </StackPanel>

                    <Button x:Name="BtnAddrep" Content="+" FontSize="20" FontWeight="DemiBold" HorizontalAlignment="Left" Width="40" Height="40" Margin="190,5,0,0" Grid.Row="1" VerticalAlignment="Top" Click="BtnAddrep_Click"/>

                    <StackPanel x:Name="StackCantidadRep" Grid.Row="0" Grid.Column="1">
                        <TextBox x:Name="Tb1CantRep" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="100" Height="40" Margin="5" TextChanged="Tb1CantRep_TextChanged"/>
                    </StackPanel>

                    <StackPanel x:Name="StackEliminarCmb" Grid.Row="0" Grid.Column="2">
                        <Button x:Name="BtnEliminar" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="50" Height="40" Margin="5" Content="-" Foreground="Red" Visibility="Hidden" IsEnabled="False"/>
                    </StackPanel>

                </Grid>
            </ScrollViewer>


        </Grid>



        <Rectangle  Fill="Gray" Grid.Column="3" Grid.Row="2" Margin="0,4,0,4"/>

        <Label Content="Mantenimiento" Grid.Row="1" FontSize="60" HorizontalContentAlignment="Center" Grid.Column="4"/>

        <Label Content="Fech. Inicio"  Grid.Row="2" Grid.Column="4" FontWeight="Bold" FontSize="25" Margin="20,50,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <DatePicker x:Name="DPFechaInicio" Grid.Row="2" Grid.Column="4" Margin="270,50,0,0" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <Label Content="Duración (Días)"  Grid.Row="2" Grid.Column="4" FontWeight="Bold" FontSize="25" Margin="20,120,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <TextBox  x:Name="TbDuracion" Margin="270,123,0,0" Grid.Row="2" Grid.Column="4" Height="40" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top" PreviewTextInput="TextBox_PreviewTextInput" PreviewKeyDown= "TextBox_PreviewKeyDown"/>

        <Label Content="Observaciones:"  Grid.Row="2" Grid.Column="4" FontWeight="Bold" FontSize="25" Margin="20,190,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <TextBox  x:Name="TbOservaciones" Margin="270,190,0,0" Grid.Row="2" Grid.Column="4" Height="135" Width="200" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap"/>

        <Label Content="Paga Adelantado:"  Grid.Row="2" Grid.Column="4" FontWeight="Bold" FontSize="25" Margin="20,320,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left" Visibility="Collapsed"/>
        <StackPanel  Margin="270,320,0,0"  Grid.Row="2" Grid.Column="4" Orientation="Horizontal" Height="40" Width="Auto" MaxWidth="200" VerticalAlignment="Top" HorizontalAlignment="Left" Visibility="Collapsed">
            
        </StackPanel>

        <Label Content="Servicios:"  Grid.Row="2" Grid.Column="4" FontWeight="Bold" FontSize="25" Margin="20,390,0,0" Width="Auto" Height="Auto" VerticalAlignment="Top" HorizontalAlignment="Left"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="270,390,0,0" Width="Auto" Height="Auto" MaxHeight="300" Grid.Column="5" Grid.Row="3">

            <Grid Width="Auto" VerticalAlignment="Top" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="StackServices" Grid.Row="0" Grid.Column="0">
                    <ComboBox x:Name="Cb1Services" Width="150" Height="40" Margin="5" SelectionChanged="Cb1Services_SelectionChanged"/>

                </StackPanel>

                <StackPanel x:Name="btnBorrarServicios" Grid.Column="1">
                    <Button  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="50" Height="40" Margin="5" Content="-" Foreground="Red" Visibility="Hidden" IsEnabled="False"/>
                </StackPanel>

                <Button x:Name="BtnAddServices" Content="+" FontSize="20" FontWeight="DemiBold" HorizontalAlignment="Right" Width="40" Height="40" Margin="5" Grid.Row="1" Click="BtnAddServices_Click"/>
            </Grid>
        </ScrollViewer>


    </Grid>
</UserControl>
